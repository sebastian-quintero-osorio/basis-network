# Basis Network - Adapter Configuration
# Copy to .env and fill in values

RPC_URL=http://<NODE_IP>:9650/ext/bc/<BLOCKCHAIN_ID>/rpc
PRIVATE_KEY=<enterprise-private-key>
CHAIN_ID=43199

# Contract addresses (from deployment output)
ENTERPRISE_REGISTRY_ADDRESS=0x...
TRACEABILITY_REGISTRY_ADDRESS=0x...
PLASMA_CONNECTOR_ADDRESS=0x...
TRACE_CONNECTOR_ADDRESS=0x...
ZK_VERIFIER_ADDRESS=0x...
