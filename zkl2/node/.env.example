# Basis Network zkEVM L2 Node -- Environment Variables
#
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must NEVER be committed.

# L1 Connection (Basis Network on Avalanche)
L1_RPC_URL=https://rpc.basisnetwork.com.co
L1_CHAIN_ID=43199
L1_PRIVATE_KEY=

# L2 Configuration
L2_CHAIN_ID=431990
L2_BLOCK_INTERVAL_MS=2000
L2_BATCH_SIZE=100
L2_GAS_LIMIT=30000000

# Deployed Contract Addresses (L1)
# Fill in after deploying zkl2/contracts/ to Fuji testnet.
BASIS_ROLLUP_ADDRESS=
BASIS_BRIDGE_ADDRESS=
BASIS_DAC_ADDRESS=
BASIS_HUB_ADDRESS=
BASIS_AGGREGATOR_ADDRESS=
BASIS_VERIFIER_ADDRESS=
ENTERPRISE_REGISTRY_ADDRESS=0xB030b8c0aE2A9b5EE4B09861E088572832cd7EA5

# Sequencer Configuration
SEQUENCER_MEMPOOL_CAPACITY=10000
SEQUENCER_FORCED_DEADLINE_BLOCKS=7200

# Proving Pipeline Configuration
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_BASE_DELAY_MS=5000
PIPELINE_PROOF_TIMEOUT_SECONDS=300
PIPELINE_MAX_CONCURRENT_BATCHES=2

# ZK Prover (Rust binary)
PROVER_BINARY_PATH=./target/release/basis-prover
PROVER_WITNESS_TIMEOUT_SECONDS=30
PROVER_PROVE_TIMEOUT_SECONDS=300

# DAC Configuration (Data Availability Committee)
DAC_ENABLED=false
DAC_THRESHOLD=5
DAC_COMMITTEE_SIZE=7
DAC_NODE_URLS=

# JSON-RPC Server
RPC_HOST=0.0.0.0
RPC_PORT=8545
RPC_RATE_LIMIT_PER_SEC=100
RPC_RATE_LIMIT_BURST=200

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
