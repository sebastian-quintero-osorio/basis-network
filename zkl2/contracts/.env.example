# Basis Network zkEVM L2 Contracts -- Environment Variables
#
# Copy to .env and fill in values before deployment.

# Deployer private key (hex, no 0x prefix)
DEPLOYER_KEY=

# L1 RPC endpoint
L1_RPC_URL=https://rpc.basisnetwork.com.co

# EnterpriseRegistry address (from L1 deployment)
ENTERPRISE_REGISTRY_ADDRESS=0xB030b8c0aE2A9b5EE4B09861E088572832cd7EA5
