# Basis Network - Smart Contract Configuration
# Copy to .env and fill in values

# Local L1 (Avalanche CLI local deployment)
RPC_URL=http://127.0.0.1:9654/ext/bc/<BLOCKCHAIN_ID>/rpc
PRIVATE_KEY=<deployer-private-key>
CHAIN_ID=43199

# Fuji testnet L1 (after avalanche blockchain deploy --fuji)
FUJI_RPC_URL=http://127.0.0.1:9650/ext/bc/<BLOCKCHAIN_ID>/rpc
