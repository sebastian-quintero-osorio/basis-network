# Basis Network - Smart Contract Configuration
# Copy to .env and fill in values

# Basis Network L1 RPC (proxied via Nginx)
RPC_URL=https://rpc.basisnetwork.com.co
PRIVATE_KEY=<deployer-private-key>
CHAIN_ID=43199

# Fuji testnet L1 (direct node access if needed)
FUJI_RPC_URL=https://rpc.basisnetwork.com.co
