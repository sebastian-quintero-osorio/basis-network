# =============================================================================
# Enterprise Node Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env files with real secrets.

# -- Identity --
ENTERPRISE_ID=enterprise-001

# -- Network (Avalanche Subnet-EVM) --
L1_RPC_URL=https://rpc.basisnetwork.com.co
L1_PRIVATE_KEY=0x...
STATE_COMMITMENT_ADDRESS=0x...

# -- ZK Circuits (production: depth=32, batch=8) --
CIRCUIT_WASM_PATH=../circuits/build/production/state_transition_js/state_transition.wasm
PROVING_KEY_PATH=../circuits/build/production/state_transition_final.zkey

# -- Batch (must match circuit batchSize parameter) --
MAX_BATCH_SIZE=8
MAX_WAIT_TIME_MS=30000

# -- WAL --
WAL_DIR=./data/wal
WAL_FSYNC=true
# HMAC key for checkpoint authentication (mitigates ADV-WAL-04 injection attack).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WAL_HMAC_KEY=

# -- Sparse Merkle Tree --
SMT_DEPTH=32

# -- Data Availability Committee --
DAC_COMMITTEE_SIZE=3
DAC_THRESHOLD=2
DAC_ENABLE_FALLBACK=true

# -- API Server --
API_HOST=0.0.0.0
API_PORT=3000

# -- Retry --
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000

# -- L1 Submission --
# Timeout (ms) for L1 transaction confirmation. Prevents indefinite hang.
L1_TX_CONFIRM_TIMEOUT_MS=120000

# -- Batch Loop --
BATCH_LOOP_INTERVAL_MS=1000

# -- Security: WAL Encryption --
# AES-256-GCM key for WAL encryption at rest (64 hex chars = 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WAL_ENCRYPTION_KEY=

# -- Security: TLS --
# Paths to TLS certificate and key files for HTTPS API server.
# If not set, the API server runs on HTTP (suitable for development).
# API_TLS_CERT=/path/to/cert.pem
# API_TLS_KEY=/path/to/key.pem

# -- Distributed DAC --
# Comma-separated gRPC endpoints for remote DAC nodes.
# When set, the orchestrator distributes shares via gRPC instead of in-process.
# Example: DAC_ENDPOINTS=dac1.example.com:50051,dac2.example.com:50051,dac3.example.com:50051
# DAC_ENDPOINTS=

# -- DAC L1 Attestation --
# DACAttestation.sol contract address on L1.
# When set, DAC attestations are submitted to L1 after each batch.
# DAC_ATTESTATION_ADDRESS=0x...

# -- Logging --
LOG_LEVEL=info
