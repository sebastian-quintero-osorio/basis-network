# =============================================================================
# Enterprise Node Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env files with real secrets.

# -- Identity --
ENTERPRISE_ID=enterprise-001

# -- Network (Avalanche Subnet-EVM) --
L1_RPC_URL=https://rpc.basisnetwork.com.co
L1_PRIVATE_KEY=0x...
STATE_COMMITMENT_ADDRESS=0x...

# -- ZK Circuits --
CIRCUIT_WASM_PATH=../circuits/build/state_transition_js/state_transition.wasm
PROVING_KEY_PATH=../circuits/build/state_transition_final.zkey

# -- Batch --
MAX_BATCH_SIZE=4
MAX_WAIT_TIME_MS=30000

# -- WAL --
WAL_DIR=./data/wal
WAL_FSYNC=true

# -- Sparse Merkle Tree --
SMT_DEPTH=32

# -- Data Availability Committee --
DAC_COMMITTEE_SIZE=3
DAC_THRESHOLD=2
DAC_ENABLE_FALLBACK=true

# -- API Server --
API_HOST=0.0.0.0
API_PORT=3000

# -- Retry --
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000

# -- Batch Loop --
BATCH_LOOP_INTERVAL_MS=1000

# -- Logging --
LOG_LEVEL=info
